<script>
let projects = [
  { id: 1, name: 'โครงการปรับปรุงระบบ ERP', quarter: 'Q1', cat: 'IT & ระบบ', plan: 2500000, actual: 2350000, note: '' },
  { id: 2, name: 'แคมเปญการตลาดดิจิทัล', quarter: 'Q1', cat: 'การตลาด', plan: 800000, actual: 920000, note: 'เกินเนื่องจากต้นทุนสื่อสูงขึ้น' },
  { id: 3, name: 'พัฒนาทักษะบุคลากร', quarter: 'Q2', cat: 'ทรัพยากรบุคคล', plan: 600000, actual: 540000, note: '' },
  { id: 4, name: 'โครงการวิจัยตลาดใหม่', quarter: 'Q2', cat: 'วิจัย & พัฒนา', plan: 1200000, actual: 1380000, note: 'ขยายขอบเขตการวิจัย' },
  { id: 5, name: 'ระบบ CRM ใหม่', quarter: 'Q3', cat: 'IT & ระบบ', plan: 1800000, actual: 1650000, note: '' },
  { id: 6, name: 'โครงการประหยัดพลังงาน', quarter: 'Q3', cat: 'การดำเนินงาน', plan: 450000, actual: 430000, note: '' },
  { id: 7, name: 'งานอีเวนต์ประจำปี', quarter: 'Q4', cat: 'การตลาด', plan: 1500000, actual: 1720000, note: 'ผู้เข้าร่วมมากกว่าที่คาด' },
  { id: 8, name: 'จัดซื้ออุปกรณ์สำนักงาน', quarter: 'Q4', cat: 'การดำเนินงาน', plan: 350000, actual: 310000, note: '' },
];
let editId = null;
let barChart = null, donutChart = null;

function fmt(n) { return Math.round(n).toLocaleString('th-TH'); }
function fmtM(n) { return (n/1000000).toFixed(2) + 'M'; }

function getStatus(plan, actual) {
  const r = actual / plan;
  if (r <= 0.9) return { label: 'ต่ำกว่างบ', cls: 'badge-ok', key: 'ok' };
  if (r <= 1.0) return { label: 'อยู่ในงบ', cls: 'badge-ok', key: 'ok' };
  if (r <= 1.1) return { label: 'เกินเล็กน้อย', cls: 'badge-warn', key: 'warn' };
  return { label: 'เกินงบ', cls: 'badge-over', key: 'over' };
}

function pctColor(pct) {
  if (pct > 110) return '#E24B4A';
  if (pct > 100) return '#EF9F27';
  if (pct > 85) return '#1D9E75';
  return '#639922';
}

// PAGE NAV
const pageTitles = {
  dashboard: ['ภาพรวมงบประมาณ', 'สรุปสถานะการใช้จ่ายทั้งหมด'],
  projects: ['รายการโครงการ', 'จัดการโครงการและงบประมาณ'],
  quarterly: ['สรุปรายไตรมาส', 'ภาพรวมการใช้จ่ายแยกตามไตรมาส'],
  report: ['รายงานสรุปผู้บริหาร', 'Executive Summary Report'],
};

function showPage(id) {
  document.querySelectorAll('.page-section').forEach(el => el.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(el => {
    if (el.getAttribute('onclick') && el.getAttribute('onclick').includes(id)) el.classList.add('active');
  });
  const [title, sub] = pageTitles[id];
  document.getElementById('page-title').textContent = title;
  document.getElementById('page-sub').textContent = sub;
  renderAll();
}

function renderAll() {
  renderDashboard();
  renderProjects();
  renderQuarterly();
  renderReport();
}

// --- DASHBOARD ---
function renderDashboard() {
  const totalPlan = projects.reduce((s, p) => s + p.plan, 0);
  const totalActual = projects.reduce((s, p) => s + p.actual, 0);
  const totalVar = totalPlan - totalActual;
  const pct = totalActual / totalPlan * 100;
  const over = projects.filter(p => p.actual > p.plan).length;
  const underBudget = projects.filter(p => p.actual <= p.plan * 0.9).length;

  document.getElementById('exec-header-block').innerHTML = `
    <div class="exec-header">
      <h2>สรุปสถานะงบประมาณ ปี 2568</h2>
      <p>อัปเดตล่าสุด: ${new Date().toLocaleDateString('th-TH', {year:'numeric',month:'long',day:'numeric'})}</p>
      <div class="exec-stats">
        <div class="exec-stat">
          <div class="es-label">งบรวม (Plan)</div>
          <div class="es-value">฿${fmtM(totalPlan)}</div>
          <div class="es-sub">${projects.length} โครงการ</div>
        </div>
        <div class="exec-stat">
          <div class="es-label">จ่ายจริง (Actual)</div>
          <div class="es-value" style="color:${totalActual>totalPlan?'#F09595':'#9FE1CB'}">฿${fmtM(totalActual)}</div>
          <div class="es-sub">${pct.toFixed(1)}% ของงบรวม</div>
        </div>
        <div class="exec-stat">
          <div class="es-label">ส่วนต่าง (Variance)</div>
          <div class="es-value" style="color:${totalVar<0?'#F09595':'#9FE1CB'}">฿${fmtM(Math.abs(totalVar))}</div>
          <div class="es-sub">${totalVar >= 0 ? 'ต่ำกว่างบ' : 'เกินงบ'}</div>
        </div>
        <div class="exec-stat">
          <div class="es-label">โครงการเกินงบ</div>
          <div class="es-value" style="color:${over>0?'#F09595':'#9FE1CB'}">${over}</div>
          <div class="es-sub">จาก ${projects.length} โครงการ</div>
        </div>
      </div>
    </div>`;

  document.getElementById('metrics-grid').innerHTML = `
    <div class="metric-card accent-blue">
      <div class="metric-label">งบรวมทั้งหมด (Plan)</div>
      <div class="metric-value">฿${fmt(totalPlan)}</div>
      <div class="metric-sub">${projects.length} โครงการ</div>
    </div>
    <div class="metric-card ${totalActual > totalPlan ? 'accent-red' : 'accent-green'}">
      <div class="metric-label">จ่ายจริงรวม (Actual)</div>
      <div class="metric-value" style="color:${totalActual > totalPlan ? 'var(--red)' : 'inherit'}">฿${fmt(totalActual)}</div>
      <div class="metric-sub">${pct.toFixed(1)}% ของงบ</div>
    </div>
    <div class="metric-card ${totalVar < 0 ? 'accent-red' : 'accent-green'}">
      <div class="metric-label">ส่วนต่างรวม (Variance)</div>
      <div class="metric-value ${totalVar < 0 ? 'var-neg' : 'var-pos'}">
        ${totalVar < 0 ? '▲' : '▼'} ฿${fmt(Math.abs(totalVar))}
      </div>
      <div class="metric-sub">${totalVar >= 0 ? 'ต่ำกว่างบ' : 'เกินงบ'}</div>
    </div>
    <div class="metric-card accent-amber">
      <div class="metric-label">โครงการเกินงบ</div>
      <div class="metric-value" style="color:${over > 0 ? 'var(--red)' : 'var(--green)'}">${over} โครงการ</div>
      <div class="metric-sub">คิดเป็น ${projects.length > 0 ? ((over/projects.length)*100).toFixed(0) : 0}%</div>
    </div>
    <div class="metric-card accent-green">
      <div class="metric-label">โครงการอยู่ในงบ</div>
      <div class="metric-value" style="color:var(--green)">${projects.length - over} โครงการ</div>
      <div class="metric-sub">รวมต่ำกว่างบ ${underBudget} โครงการ</div>
    </div>
    <div class="metric-card accent-blue">
      <div class="metric-label">% การใช้งบรวม</div>
      <div class="metric-value" style="color:${pct>100?'var(--red)':pct>90?'var(--amber)':'var(--green)'}">${pct.toFixed(1)}%</div>
      <div class="metric-sub">${pct > 100 ? 'เกินงบ' : pct > 90 ? 'ใกล้เต็มงบ' : 'อยู่ในงบ'}</div>
    </div>`;

  renderBarChart();
  renderDonutChart();

  const recent = [...projects].slice(-5).reverse();
  document.getElementById('recent-tbody').innerHTML = recent.map(p => {
    const v = p.plan - p.actual;
    const st = getStatus(p.plan, p.actual);
    return `<tr>
      <td><div class="project-name">${p.name}</div><div class="project-cat">${p.cat}</div></td>
      <td><span style="font-size:12px;font-weight:600;color:var(--blue)">${p.quarter}</span></td>
      <td class="num-right">฿${fmt(p.plan)}</td>
      <td class="num-right">฿${fmt(p.actual)}</td>
      <td class="num-right ${v >= 0 ? 'var-pos' : 'var-neg'}">${v < 0 ? '▲' : '▼'} ฿${fmt(Math.abs(v))}</td>
      <td><span class="badge ${st.cls}">${st.label}</span></td>
    </tr>`;
  }).join('');
}

function renderBarChart() {
  const qs = ['Q1','Q2','Q3','Q4'];
  const planD = qs.map(q => projects.filter(p=>p.quarter===q).reduce((s,p)=>s+p.plan,0));
  const actD  = qs.map(q => projects.filter(p=>p.quarter===q).reduce((s,p)=>s+p.actual,0));
  const bgAct = actD.map((a,i) => a > planD[i] ? '#E24B4A' : '#1D9E75');
  if (barChart) barChart.destroy();
  barChart = new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
      labels: qs,
      datasets: [
        { label: 'Plan', data: planD, backgroundColor: 'rgba(55,138,221,0.25)', borderColor: '#378ADD', borderWidth: 1.5 },
        { label: 'Actual', data: actD, backgroundColor: bgAct, borderColor: bgAct, borderWidth: 1 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: {
        callbacks: { label: ctx => ctx.dataset.label + ': ฿' + fmt(ctx.raw) }
      }},
      scales: {
        y: { ticks: { callback: v => '฿'+fmtM(v), color: '#9C9B93', font:{size:11} }, grid: { color: 'rgba(0,0,0,0.05)' }, border:{display:false} },
        x: { ticks: { color: '#9C9B93', font:{size:12} }, grid: { display: false }, border:{display:false} }
      }
    }
  });
}

function renderDonutChart() {
  const cats = [...new Set(projects.map(p=>p.cat))];
  const data = cats.map(c => projects.filter(p=>p.cat===c).reduce((s,p)=>s+p.actual,0));
  const colors = ['#378ADD','#1D9E75','#EF9F27','#E24B4A','#9370DB','#20B2AA'];
  if (donutChart) donutChart.destroy();
  donutChart = new Chart(document.getElementById('donutChart'), {
    type: 'doughnut',
    data: {
      labels: cats,
      datasets: [{ data, backgroundColor: colors.slice(0,cats.length), borderWidth: 2, borderColor: '#FFFFFF' }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position:'bottom', labels:{ font:{size:11}, boxWidth:10, padding:10, color:'#6B6960' }},
        tooltip: { callbacks: { label: ctx => ctx.label + ': ฿' + fmt(ctx.raw) }}
      },
      cutout: '60%'
    }
  });
}

// --- PROJECTS ---
function renderProjects() {
  const q = document.getElementById('filter-quarter')?.value || '';
  const s = document.getElementById('filter-status')?.value || '';
  const search = (document.getElementById('search-input')?.value || '').toLowerCase();
  let filtered = projects.filter(p => {
    if (q && p.quarter !== q) return false;
    if (s && getStatus(p.plan, p.actual).key !== s) return false;
    if (search && !p.name.toLowerCase().includes(search) && !p.cat.toLowerCase().includes(search)) return false;
    return true;
  });
  document.getElementById('project-count-label').textContent = `แสดง ${filtered.length} จาก ${projects.length} โครงการ`;
  const tbody = document.getElementById('projects-tbody');
  if (!filtered.length) {
    tbody.innerHTML = `<tr><td colspan="9"><div class="empty-state"><div class="empty-icon">📭</div><h3>ไม่พบโครงการ</h3><p>ลองเปลี่ยนตัวกรองหรือเพิ่มโครงการใหม่</p></div></td></tr>`;
    document.getElementById('projects-tfoot').innerHTML = '';
    return;
  }
  tbody.innerHTML = filtered.map(p => {
    const v = p.plan - p.actual;
    const pct = (p.actual / p.plan * 100);
    const st = getStatus(p.plan, p.actual);
    const barW = Math.min(pct, 130);
    return `<tr>
      <td><div class="project-name">${p.name}</div>${p.note ? `<div class="project-cat">${p.note}</div>` : ''}</td>
      <td><span style="font-size:12px;font-weight:600;color:var(--blue)">${p.quarter}</span></td>
      <td><span style="font-size:12px;color:var(--text2)">${p.cat}</span></td>
      <td class="num-right">฿${fmt(p.plan)}</td>
      <td class="num-right">฿${fmt(p.actual)}</td>
      <td class="num-right ${v >= 0 ? 'var-pos' : 'var-neg'}">${v < 0 ? '▲' : '▼'} ฿${fmt(Math.abs(v))}</td>
      <td class="num-right">
        <span style="font-size:12px;font-weight:500;color:${pctColor(pct)}">${pct.toFixed(1)}%</span>
        <div class="pct-bar-wrap"><div class="pct-bar" style="width:${barW}%;background:${pctColor(pct)}"></div></div>
      </td>
      <td><span class="badge ${st.cls}">${st.label}</span></td>
      <td style="text-align:center">
        <div style="display:flex;gap:6px;justify-content:center">
          <button class="btn btn-sm" onclick="editProject(${p.id})">แก้ไข</button>
          <button class="btn btn-sm btn-danger" onclick="deleteProject(${p.id})">ลบ</button>
        </div>
      </td>
    </tr>`;
  }).join('');

  const tPlan = filtered.reduce((s,p) => s+p.plan,0);
  const tActual = filtered.reduce((s,p) => s+p.actual,0);
  const tVar = tPlan - tActual;
  document.getElementById('projects-tfoot').innerHTML = `<tr>
    <td colspan="3" style="font-weight:600">รวม (${filtered.length} โครงการ)</td>
    <td class="num-right">฿${fmt(tPlan)}</td>
    <td class="num-right">฿${fmt(tActual)}</td>
    <td class="num-right ${tVar >= 0 ? 'var-pos' : 'var-neg'}">${tVar < 0 ? '▲' : '▼'} ฿${fmt(Math.abs(tVar))}</td>
    <td class="num-right">${(tActual/tPlan*100).toFixed(1)}%</td>
    <td colspan="2"></td>
  </tr>`;
}

// --- QUARTERLY ---
function renderQuarterly() {
  const qs = ['Q1','Q2','Q3','Q4'];
  const qLabels = { Q1:'ม.ค.–มี.ค.', Q2:'เม.ย.–มิ.ย.', Q3:'ก.ค.–ก.ย.', Q4:'ต.ค.–ธ.ค.' };
  document.getElementById('quarter-cards').innerHTML = qs.map(q => {
    const qp = projects.filter(p=>p.quarter===q);
    if (!qp.length) return `<div class="q-card"><div class="q-title">${q}</div><div class="q-sub">${qLabels[q]}</div><p style="font-size:12px;color:var(--text3)">ไม่มีโครงการ</p></div>`;
    const plan = qp.reduce((s,p)=>s+p.plan,0);
    const actual = qp.reduce((s,p)=>s+p.actual,0);
    const v = plan - actual;
    const pct = actual/plan*100;
    const over = qp.filter(p=>p.actual>p.plan).length;
    return `<div class="q-card">
      <div class="q-title">${q}</div>
      <div class="q-sub">${qLabels[q]} · ${qp.length} โครงการ</div>
      <div class="q-stat"><span class="label">Plan</span><span class="value">฿${fmt(plan)}</span></div>
      <div class="q-stat"><span class="label">Actual</span><span class="value" style="color:${actual>plan?'var(--red)':'inherit'}">฿${fmt(actual)}</span></div>
      <div class="q-stat"><span class="label">Variance</span><span class="value ${v>=0?'var-pos':'var-neg'}">${v<0?'▲':'▼'} ฿${fmt(Math.abs(v))}</span></div>
      <div class="q-stat"><span class="label">เกินงบ</span><span class="value" style="color:${over>0?'var(--red)':'var(--green)'}">${over} โครงการ</span></div>
      <div class="q-progress"><div class="q-fill" style="width:${Math.min(pct,130)}%;background:${pctColor(pct)}"></div></div>
      <div class="q-pct">${pct.toFixed(1)}% ใช้แล้ว</div>
    </div>`;
  }).join('');

  let detailHTML = '';
  qs.forEach(q => {
    const qp = projects.filter(p=>p.quarter===q);
    if (!qp.length) return;
    detailHTML += `<div style="padding:16px 22px;border-bottom:1px solid var(--border)">
      <div style="font-size:13px;font-weight:600;margin-bottom:12px;color:var(--blue)">${q} — ${qLabels[q]}</div>
      <table style="width:100%;font-size:12px;border-collapse:collapse">
        <thead><tr style="background:var(--surface2)">
          <th style="padding:8px 10px;text-align:left;border:1px solid var(--border);font-weight:600">โครงการ</th>
          <th style="padding:8px 10px;text-align:right;border:1px solid var(--border);font-weight:600">Plan</th>
          <th style="padding:8px 10px;text-align:right;border:1px solid var(--border);font-weight:600">Actual</th>
          <th style="padding:8px 10px;text-align:right;border:1px solid var(--border);font-weight:600">Variance</th>
          <th style="padding:8px 10px;text-align:center;border:1px solid var(--border);font-weight:600">สถานะ</th>
        </tr></thead>
        <tbody>
        ${qp.map(p => {
          const v = p.plan - p.actual;
          const st = getStatus(p.plan, p.actual);
          return `<tr>
            <td style="padding:7px 10px;border:1px solid var(--border)">${p.name} <span style="color:var(--text3);font-size:11px">(${p.cat})</span></td>
            <td style="padding:7px 10px;border:1px solid var(--border);text-align:right">฿${fmt(p.plan)}</td>
            <td style="padding:7px 10px;border:1px solid var(--border);text-align:right">฿${fmt(p.actual)}</td>
            <td style="padding:7px 10px;border:1px solid var(--border);text-align:right;${v<0?'color:var(--red)':'color:var(--green)'}">${v<0?'▲':'▼'} ฿${fmt(Math.abs(v))}</td>
            <td style="padding:7px 10px;border:1px solid var(--border);text-align:center"><span class="badge ${st.cls}">${st.label}</span></td>
          </tr>`;
        }).join('')}
        </tbody>
        <tfoot>
          <tr style="background:var(--surface2);font-weight:600">
            <td style="padding:8px 10px;border:1px solid var(--border)">รวม ${q}</td>
            <td style="padding:8px 10px;border:1px solid var(--border);text-align:right">฿${fmt(qp.reduce((s,p)=>s+p.plan,0))}</td>
            <td style="padding:8px 10px;border:1px solid var(--border);text-align:right">฿${fmt(qp.reduce((s,p)=>s+p.actual,0))}</td>
            <td style="padding:8px 10px;border:1px solid var(--border);text-align:right">${(() => { const v = qp.reduce((s,p)=>s+p.plan,0) - qp.reduce((s,p)=>s+p.actual,0); return `<span style="color:${v<0?'var(--red)':'var(--green)'}">${v<0?'▲':'▼'} ฿${fmt(Math.abs(v))}</span>`; })()}</td>
            <td style="padding:8px 10px;border:1px solid var(--border)"></td>
          </tr>
        </tfoot>
      </table>
    </div>`;
  });
  document.getElementById('quarter-detail-tables').innerHTML = detailHTML;
}

// --- REPORT ---
function renderReport() {
  const totalPlan = projects.reduce((s,p)=>s+p.plan,0);
  const totalActual = projects.reduce((s,p)=>s+p.actual,0);
  const totalVar = totalPlan - totalActual;
  const pct = totalActual/totalPlan*100;
  const over = projects.filter(p=>p.actual>p.plan);
  const under = projects.filter(p=>p.actual<=p.plan*0.9);

  document.getElementById('exec-report-block').innerHTML = `
    <div class="exec-header" style="margin-bottom:20px">
      <h2>รายงานสรุปผู้บริหาร — ปีงบประมาณ 2568</h2>
      <p>วันที่จัดทำ: ${new Date().toLocaleDateString('th-TH', {year:'numeric',month:'long',day:'numeric'})}</p>
      <div class="exec-stats">
        <div class="exec-stat"><div class="es-label">งบรวม (Plan)</div><div class="es-value">฿${fmtM(totalPlan)}</div><div class="es-sub">${projects.length} โครงการ</div></div>
        <div class="exec-stat"><div class="es-label">จ่ายจริง (Actual)</div><div class="es-value" style="color:${totalActual>totalPlan?'#F09595':'#9FE1CB'}">฿${fmtM(totalActual)}</div><div class="es-sub">${pct.toFixed(1)}%</div></div>
        <div class="exec-stat"><div class="es-label">Variance</div><div class="es-value" style="color:${totalVar<0?'#F09595':'#9FE1CB'}">฿${fmtM(Math.abs(totalVar))}</div><div class="es-sub">${totalVar>=0?'ต่ำกว่างบ':'เกินงบ'}</div></div>
      </div>
    </div>`;

  document.getElementById('report-summary').innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
      <div style="border:1px solid var(--border);border-radius:var(--r-md);padding:16px">
        <div style="font-size:12px;font-weight:600;color:var(--red);margin-bottom:8px">⚠️ โครงการเกินงบ (${over.length} โครงการ)</div>
        ${over.length ? over.map(p=>`<div style="font-size:12px;padding:4px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between"><span>${p.name}</span><span style="color:var(--red);font-weight:500">+฿${fmt(p.actual-p.plan)}</span></div>`).join('') : '<div style="font-size:12px;color:var(--green)">✓ ไม่มีโครงการเกินงบ</div>'}
      </div>
      <div style="border:1px solid var(--border);border-radius:var(--r-md);padding:16px">
        <div style="font-size:12px;font-weight:600;color:var(--green);margin-bottom:8px">✅ โครงการประหยัดงบ (${under.length} โครงการ)</div>
        ${under.map(p=>`<div style="font-size:12px;padding:4px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between"><span>${p.name}</span><span style="color:var(--green);font-weight:500">-฿${fmt(p.plan-p.actual)}</span></div>`).join('')}
      </div>
    </div>`;

  document.getElementById('report-tbody').innerHTML = projects.map((p, i) => {
    const v = p.plan - p.actual;
    const pctVal = (p.actual/p.plan*100);
    const st = getStatus(p.plan, p.actual);
    return `<tr>
      <td style="color:var(--text3)">${i+1}</td>
      <td><div style="font-size:13px;font-weight:500">${p.name}</div></td>
      <td>${p.quarter}</td><td style="font-size:12px;color:var(--text2)">${p.cat}</td>
      <td class="num-right">฿${fmt(p.plan)}</td>
      <td class="num-right">฿${fmt(p.actual)}</td>
      <td class="num-right ${v>=0?'var-pos':'var-neg'}">${v<0?'▲':'▼'} ฿${fmt(Math.abs(v))}</td>
      <td class="num-right" style="color:${pctColor(pctVal)};font-weight:500">${pctVal.toFixed(1)}%</td>
      <td><span class="badge ${st.cls}">${st.label}</span></td>
    </tr>`;
  }).join('');

  const tPlan = projects.reduce((s,p)=>s+p.plan,0);
  const tActual = projects.reduce((s,p)=>s+p.actual,0);
  const tVar = tPlan - tActual;
  document.getElementById('report-tfoot').innerHTML = `<tr>
    <td colspan="4" style="font-weight:600">รวมทั้งหมด (${projects.length} โครงการ)</td>
    <td class="num-right">฿${fmt(tPlan)}</td>
    <td class="num-right">฿${fmt(tActual)}</td>
    <td class="num-right ${tVar>=0?'var-pos':'var-neg'}">${tVar<0?'▲':'▼'} ฿${fmt(Math.abs(tVar))}</td>
    <td class="num-right">${(tActual/tPlan*100).toFixed(1)}%</td>
    <td></td>
  </tr>`;
}

// --- MODAL ---
function openModal(id) {
  editId = id || null;
  if (editId) {
    const p = projects.find(x=>x.id===editId);
    document.getElementById('modal-title').textContent = 'แก้ไขโครงการ';
    document.getElementById('f-name').value = p.name;
    document.getElementById('f-quarter').value = p.quarter;
    document.getElementById('f-cat').value = p.cat;
    document.getElementById('f-plan').value = p.plan;
    document.getElementById('f-actual').value = p.actual;
    document.getElementById('f-note').value = p.note || '';
  } else {
    document.getElementById('modal-title').textContent = 'เพิ่มโครงการใหม่';
    document.getElementById('f-name').value = '';
    document.getElementById('f-plan').value = '';
    document.getElementById('f-actual').value = '';
    document.getElementById('f-note').value = '';
  }
  document.getElementById('modal-backdrop').classList.add('open');
  setTimeout(() => document.getElementById('f-name').focus(), 100);
}

function closeModal() { document.getElementById('modal-backdrop').classList.remove('open'); }

function saveProject() {
  const name = document.getElementById('f-name').value.trim();
  const quarter = document.getElementById('f-quarter').value;
  const cat = document.getElementById('f-cat').value;
  const plan = parseFloat(document.getElementById('f-plan').value) || 0;
  const actual = parseFloat(document.getElementById('f-actual').value) || 0;
  const note = document.getElementById('f-note').value.trim();
  if (!name) { showToast('กรุณากรอกชื่อโครงการ', 'error'); return; }
  if (!plan) { showToast('กรุณากรอกงบที่ตั้งไว้', 'error'); return; }
  if (editId) {
    const i = projects.findIndex(p=>p.id===editId);
    projects[i] = { ...projects[i], name, quarter, cat, plan, actual, note };
    showToast('แก้ไขโครงการสำเร็จ', 'success');
  } else {
    projects.push({ id: Date.now(), name, quarter, cat, plan, actual, note });
    showToast('เพิ่มโครงการสำเร็จ', 'success');
  }
  closeModal();
  renderAll();
}

function editProject(id) { openModal(id); }

function deleteProject(id) {
  const p = projects.find(x=>x.id===id);
  if (!confirm(`ต้องการลบ "${p.name}" ใช่หรือไม่?`)) return;
  projects = projects.filter(x=>x.id!==id);
  showToast('ลบโครงการสำเร็จ');
  renderAll();
}

// --- EXPORT ---
function exportCSV() {
  const headers = ['ชื่อโครงการ','ไตรมาส','หมวดหมู่','Plan (บาท)','Actual (บาท)','Variance (บาท)','% ใช้จ่าย','สถานะ'];
  const rows = projects.map(p => {
    const v = p.plan - p.actual;
    const pct = (p.actual/p.plan*100).toFixed(1);
    const st = getStatus(p.plan,p.actual);
    return [p.name, p.quarter, p.cat, p.plan, p.actual, v, pct+'%', st.label];
  });
  const csv = [headers, ...rows].map(r => r.map(c => `"${c}"`).join(',')).join('\n');
  const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `budget-report-${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  showToast('ส่งออก CSV สำเร็จ', 'success');
}

// --- TOAST ---
function showToast(msg, type = '') {
  const tc = document.getElementById('toast-container');
  const t = document.createElement('div');
  t.className = 'toast ' + type;
  t.textContent = msg;
  tc.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}

// KEYBOARD
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeModal();
});
document.getElementById('modal-backdrop').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeModal();
});

// INIT
renderAll();
</script>
